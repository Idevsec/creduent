{
  "crons": [
    {
      "path": "/api/cron/renew",
      "schedule": "0 0 * * *"
    }
  ],
  "builds": [

    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "registry/main.py",
      "use": "@vercel/python"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "creduent.idevsec.com"
        }
      ],
      "destination": "https://creduent.idevsec.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "registry.idevsec.com"
        }
      ],
      "destination": "https://creduent.idevsec.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/resolver",
      "destination": "/registry/main.py"
    },
    {
      "source": "/resolver/(.*)",
      "destination": "/registry/main.py"
    },
    {
      "source": "/agent:path(.*)",
      "destination": "/registry/main.py"
    },
    {
      "source": "/registry",
      "destination": "/registry/main.py"
    },
    {
      "source": "/registry/(.*)",
      "destination": "/registry/main.py"
    },
    {
      "source": "/dashboard",
      "destination": "/registry/main.py"
    },
    {
      "source": "/dashboard/(.*)",
      "destination": "/registry/main.py"
    },
    {
      "source": "/renew",
      "destination": "/registry/main.py"
    },
    {
      "source": "/renew/(.*)",
      "destination": "/registry/main.py"
    },
    {
      "source": "/webhook",
      "destination": "/registry/main.py"
    },
    {
      "source": "/webhook/(.*)",
      "destination": "/registry/main.py"
    },
    {
      "source": "/attest",
      "destination": "/registry/main.py"
    },
    {
      "source": "/attest/(.*)",
      "destination": "/registry/main.py"
    },
    {
      "source": "/admin/attest",
      "destination": "/registry/main.py"
    },
    {
      "source": "/stats",
      "destination": "/registry/main.py"
    },
    {
      "source": "/stats/(.*)",
      "destination": "/registry/main.py"
    },
    {
      "source": "/revoke/(.*)",
      "destination": "/registry/main.py"
    },
    {
      "source": "/register",
      "destination": "/registry/main.py"
    },
    {
      "source": "/agents",
      "destination": "/registry/main.py"
    },
    {
      "source": "/challenge/(.*)",
      "destination": "/registry/main.py"
    },
    {
      "source": "/verify-challenge",
      "destination": "/registry/main.py"
    },
    {
      "source": "/public-key",
      "destination": "/registry/main.py"
    },
    {
      "source": "/health",
      "destination": "/registry/main.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/.well-known/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/",
      "destination": "/api/index.py"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, CREDUENT-ADMIN-KEY, CREDUENT_ADMIN_KEY"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        }
      ]
    }
  ]
}
