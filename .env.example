# AXI Registry & MCP Server Configuration Template
# Copy this file to .env.local and fill in the values below.

# 1. Cryptographic Keys
# Registry Private Key (Ed25519) - Used by registry/main.py to sign attestations.
# Can be PEM-encoded (with line breaks) or a single-line Base64 string of the PEM key.
# Generate via: python cli/aix-sign.py generate-keys
AXI_REGISTRY_KEY="YOUR_BASE64_OR_PEM_REGISTRY_PRIVATE_KEY"

# Registry Public Key - Used by mcp/axi_mcp_server.py to verify attestation signatures.
# Format: ed25519:<base64-public-key>
AXI_REGISTRY_PUBKEY="ed25519:YOUR_BASE64_REGISTRY_PUBLIC_KEY"

# 2. Administrative Security
# Key required in AXI-ADMIN-KEY header to perform agent revocation (DELETE /revoke/{agent_id})
# Should be a secure 32-byte hex string (e.g. generated via `openssl rand -hex 32`)
AXI_ADMIN_KEY="YOUR_SECURE_ADMIN_REVOCATION_KEY"

# 3. Connection & Routing Configurations
# Registry Server URL used by the MCP server tool (defaults to http://localhost:8001 if omitted)
AXI_REGISTRY_URL="http://localhost:8001"

# 4. Persistent Storage - Vercel KV (Upstash Redis)
# Optional: If these are provided, the registry store will persist to Upstash Redis.
# If omitted, it automatically falls back to local file storage (registry_db.json).
UPSTASH_REDIS_REST_URL="YOUR_UPSTASH_REDIS_REST_URL"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_REDIS_REST_TOKEN"
